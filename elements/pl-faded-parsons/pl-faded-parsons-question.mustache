
<div id="pl-faded-parsons-aria-details-{{uuid}}" class="aria-details soft-border" role="status" aria-live="assertive" aria-atomic="true"></div>
<div id="pl-faded-parsons-aria-descriptor-{{uuid}}" class="aria-descriptor soft-border"></div>

{{! the boxes for starter code and solution area}}

{{! if not vertical (horizontal), keep half size boxes }}
{{! if vertical (or one-tray), full size boxes }}
<div
    id="pl-faded-parsons-{{uuid}}"
    role="application"
    tabindex="0"
    aria-labelledby="pl-faded-parsons-aria-descriptor-{{uuid}}"
    aria-details="pl-faded-parsons-aria-details-{{uuid}}"
    language="{{language}}"
    class="
        col fpp-global-defs pl-faded-parsons soft-border
        {{#borderless}}pl-faded-parsons-borderless{{/borderless}}
        {{#bottom_layout}}pl-faded-parsons-bottom-layout{{/bottom_layout}}
        {{^starter}}{{^pre_text}}{{^post_text}}pl-faded-parsons-solution-only{{/post_text}}{{/pre_text}}{{/starter}}
    "
>
    {{! form field to be filled with order to save the current submission }}
    <input class="main" name="{{answers_name}}.main" type="hidden" value=""/>
    <input class="log" name="{{answers_name}}.log" type="hidden" value="{{previous_log}}" />

    <div class="row pl-faded-parsons-layout-row">
        {{#starter}}
        <div
            id="starter-code-{{uuid}}"
            class="starter-code-tray codeline-tray soft-border col-sm-{{#narrow}}6 fpp-tray-flex{{/narrow}}{{#wide}}12{{/wide}} px-1"
        >
            <span class="fpp-tray-corner-label fpp-tray-corner-label-starter" aria-hidden="true">unused</span>
            <ol id="ol-starter-code-{{uuid}}" class="ui-sortable codeline-list">
                {{#lines}}
                    {{> pl-faded-parsons-code-line}}
                {{/lines}}
            </ol>
        </div>
        {{/starter}}
        {{#pre_text}}
        <div class="pre-text-wrapper">
            <pre class="prettyprint pre-text" language="{{language}}">{{{text}}}</pre>
        </div>
        {{/pre_text}}
        {{#solution}}
        <div
            id="solution-{{uuid}}"
            class="solution-code-tray codeline-tray soft-border col-sm-{{#narrow}}6 fpp-tray-flex{{/narrow}}{{#wide}}12{{/wide}} {{^wide}}px-1{{/wide}}"
        >
            {{#starter}}
            <span class="fpp-tray-corner-label fpp-tray-corner-label-solution" aria-hidden="true">solution</span>
            {{/starter}}
            <ol id="ol-solution-{{uuid}}" class="ui-sortable codeline-list output">
                {{#lines}}
                    {{> pl-faded-parsons-code-line}}
                {{/lines}}
            </ol>
            <div id="widget-controls-{{uuid}}" class="fpp-floating-controls">
                {{#enable_copy_code}}
                <a role="button" aria-label="copy to clipboard" class="widget-copy btn btn-light border d-flex align-items-center" tabindex="0">
                    <svg fill="#000000" width="16px" height="16px" viewBox="0 0 32 32" data-name="Layer 1" id="Layer_1" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M27.2,8.22H23.78V5.42A3.42,3.42,0,0,0,20.36,2H5.42A3.42,3.42,0,0,0,2,5.42V20.36a3.43,3.43,0,0,0,3.42,3.42h2.8V27.2A2.81,2.81,0,0,0,11,30H27.2A2.81,2.81,0,0,0,30,27.2V11A2.81,2.81,0,0,0,27.2,8.22ZM5.42,21.91a1.55,1.55,0,0,1-1.55-1.55V5.42A1.54,1.54,0,0,1,5.42,3.87H20.36a1.55,1.55,0,0,1,1.55,1.55v2.8H11A2.81,2.81,0,0,0,8.22,11V21.91ZM28.13,27.2a.93.93,0,0,1-.93.93H11a.93.93,0,0,1-.93-.93V11a.93.93,0,0,1,.93-.93H27.2a.93.93,0,0,1,.93.93Z"></path>
                    </svg>
                </a>
                {{/enable_copy_code}}
                {{! not using <button> is an accessibility anti-pattern that is forced by prairielearn }}
                <a role="button" aria-label="help text" class="widget-help btn btn-light border d-flex align-items-center" tabindex="0">
                    <i class="fa fa-question-circle" aria-hidden="true"></i>
                </a>
            </div>
        </div>
        {{/solution}}
        {{#post_text}}
        <div class="post-text-wrapper">
            <pre class="prettyprint post-text" language="{{language}}">{{{text}}}</pre>
        </div>
        {{/post_text}}
    </div>

</div>

<script>
    $(document).ready(() => {
        new ParsonsWidget({
            main: '#pl-faded-parsons-{{uuid}}',
            uuid: '{{uuid}}',
            {{#bottom_layout}}
            layout: "bottom",
            {{/bottom_layout}}
            {{#logging_enabled}}
            loggingEnabled: true,
            {{/logging_enabled}}

            maxIndentLevel: {{max_indent_level}},
            visualIndent: {{visual_indent}},

            logStorage: "#pl-faded-parsons-{{uuid}} > input.log",
            storage: "#pl-faded-parsons-{{uuid}} > input.main",

            ariaDescriptor: "#pl-faded-parsons-aria-descriptor-{{uuid}}",
            ariaDetails: "#pl-faded-parsons-aria-details-{{uuid}}",
            toolbar: "#widget-controls-{{uuid}}",

            solution: '#solution-{{uuid}}',
            solutionList: '#ol-solution-{{uuid}}',
            {{#starter}}
            starter: '#starter-code-{{uuid}}',
            starterList: '#ol-starter-code-{{uuid}}',
            {{/starter}}
        });
    });
</script>
